#!/usr/bin/env bash
set -Eeuo pipefail

REPO_URL="https://github.com/zealdocs/zeal.git"
REPO_DIR="${HOME}/src/zeal"
BUILD_DIR="${REPO_DIR}/build"
APP_DEST="${HOME}/Applications"
GITHUB_API_RELEASE="https://api.github.com/repos/zealdocs/zeal/releases/latest"
GITHUB_API_TAGS="https://api.github.com/repos/zealdocs/zeal/tags"
FORCE_BUILD=0
CHECK_ONLY=0

log()  { printf "\033[1;34m[INFO]\033[0m %s\n" "$*"; }
warn() { printf "\033[1;33m[WARN]\033[0m %s\n" "$*" >&2; }
err()  { printf "\033[1;31m[ERR ]\033[0m %s\n" "$*" >&2; }

usage() {
  cat <<EOF
Usage: $(basename "$0") [options]

Options:
  --force           Build even if local source appears current
  --check-only      Only check versions; do not build
  --repo-dir PATH   Override repo location (default: ${REPO_DIR})
  --app-dest PATH   Override app install destination (default: ${APP_DEST})
  -h, --help        Show this help
EOF
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || {
    err "Required command not found: $1"
    exit 1
  }
}

cleanup_on_error() {
  err "Build failed on line $1"
}
trap 'cleanup_on_error $LINENO' ERR

while [[ $# -gt 0 ]]; do
  case "$1" in
    --force) FORCE_BUILD=1; shift ;;
    --check-only) CHECK_ONLY=1; shift ;;
    --repo-dir) REPO_DIR="$2"; BUILD_DIR="${REPO_DIR}/build"; shift 2 ;;
    --app-dest) APP_DEST="$2"; shift 2 ;;
    -h|--help) usage; exit 0 ;;
    *) err "Unknown option: $1"; usage; exit 1 ;;
  esac
done

require_cmd git
require_cmd curl
require_cmd cmake
require_cmd brew
require_cmd python3

if ! xcode-select -p >/dev/null 2>&1; then
  err "Xcode/Command Line Tools not configured. Install Xcode first."
  exit 1
fi

if [[ ! -d /Applications/Xcode.app ]]; then
  warn "Full Xcode.app not found in /Applications. The wiki recommends installing Xcode from the App Store."
else
  CURRENT_DEV_DIR="$(xcode-select -p || true)"
  EXPECTED_DEV_DIR="/Applications/Xcode.app/Contents/Developer"
  if [[ "${CURRENT_DEV_DIR}" != "${EXPECTED_DEV_DIR}" ]]; then
    warn "Active developer directory is '${CURRENT_DEV_DIR}', not '${EXPECTED_DEV_DIR}'."
    warn "If builds fail, run: sudo xcode-select -s ${EXPECTED_DEV_DIR}"
  fi
fi

log "Installing/verifying dependencies from Homebrew"
brew install qt@6 libarchive vulkan-headers

QT_PREFIX="$(brew --prefix qt@6)"
LIBARCHIVE_PREFIX="$(brew --prefix libarchive)"
VULKAN_HEADERS_PREFIX="$(brew --prefix vulkan-headers)"
export CMAKE_PREFIX_PATH="${QT_PREFIX}:${LIBARCHIVE_PREFIX}:${VULKAN_HEADERS_PREFIX}"

mkdir -p "$(dirname "$REPO_DIR")"
mkdir -p "$APP_DEST"

get_latest_release_tag() {
  curl -fsSL "$GITHUB_API_RELEASE" | python3 -c '
import json,sys
data=json.load(sys.stdin)
print(data.get("tag_name",""))
' 2>/dev/null || true
}

get_latest_tag_fallback() {
  curl -fsSL "$GITHUB_API_TAGS" | python3 -c '
import json,sys
data=json.load(sys.stdin)
print(data[0]["name"] if data else "")
' 2>/dev/null || true
}

REMOTE_VERSION="$(get_latest_release_tag)"
if [[ -z "$REMOTE_VERSION" ]]; then
  warn "Could not read latest GitHub release; falling back to latest tag"
  REMOTE_VERSION="$(get_latest_tag_fallback)"
fi

if [[ -z "$REMOTE_VERSION" ]]; then
  warn "Could not determine remote version from GitHub; continuing with source update only"
else
  log "Latest remote Zeal version: ${REMOTE_VERSION}"
fi

if [[ ! -d "${REPO_DIR}/.git" ]]; then
  log "Cloning Zeal source into ${REPO_DIR}"
  git clone "$REPO_URL" "$REPO_DIR"
else
  log "Using existing repo at ${REPO_DIR}"
fi

cd "$REPO_DIR"
git fetch --tags origin

LOCAL_TAG="$(git describe --tags --abbrev=0 2>/dev/null || true)"
LOCAL_COMMIT="$(git rev-parse --short HEAD)"
log "Local repo state: tag='${LOCAL_TAG:-none}', commit='${LOCAL_COMMIT}'"

NEEDS_BUILD=0

if [[ "$FORCE_BUILD" -eq 1 ]]; then
  NEEDS_BUILD=1
  log "Force build requested"
elif [[ -n "$REMOTE_VERSION" && "$LOCAL_TAG" != "$REMOTE_VERSION" ]]; then
  NEEDS_BUILD=1
  log "Local version differs from remote version"
elif [[ ! -d "$BUILD_DIR/Zeal.app" ]]; then
  NEEDS_BUILD=1
  log "No built Zeal.app found in build directory"
else
  log "Local source appears current and app bundle exists"
fi

if [[ "$CHECK_ONLY" -eq 1 ]]; then
  if [[ "$NEEDS_BUILD" -eq 1 ]]; then
    log "Update/build is needed"
    exit 10
  else
    log "No build needed"
    exit 0
  fi
fi

if [[ "$NEEDS_BUILD" -eq 0 ]]; then
  log "Skipping build"
  exit 0
fi

if [[ -n "$REMOTE_VERSION" ]]; then
  if git rev-parse "refs/tags/${REMOTE_VERSION}" >/dev/null 2>&1; then
    log "Checking out release tag ${REMOTE_VERSION}"
    git checkout "tags/${REMOTE_VERSION}" -B "build-${REMOTE_VERSION}"
  else
    warn "Remote version tag ${REMOTE_VERSION} not found locally; using origin/master or origin/main"
    DEFAULT_BRANCH="$(git remote show origin | sed -n '/HEAD branch/s/.*: //p')"
    git checkout "${DEFAULT_BRANCH}"
    git pull --ff-only origin "${DEFAULT_BRANCH}"
  fi
else
  DEFAULT_BRANCH="$(git remote show origin | sed -n '/HEAD branch/s/.*: //p')"
  log "Updating default branch ${DEFAULT_BRANCH}"
  git checkout "${DEFAULT_BRANCH}"
  git pull --ff-only origin "${DEFAULT_BRANCH}"
fi

log "Configuring CMake"
cmake -S . -B "$BUILD_DIR" \
  -DCMAKE_PREFIX_PATH="$CMAKE_PREFIX_PATH" \
  -DCMAKE_BUILD_TYPE=Release

log "Building Zeal"
cmake --build "$BUILD_DIR" --config Release --parallel

APP_PATH="${BUILD_DIR}/Zeal.app"
if [[ ! -d "$APP_PATH" ]]; then
  err "Expected app bundle not found at ${APP_PATH}"
  exit 1
fi

log "Installing Zeal.app to ${APP_DEST}"
rm -rf "${APP_DEST}/Zeal.app"
cp -Rp "$APP_PATH" "$APP_DEST/"

log "Build and install completed successfully"
log "Installed app: ${APP_DEST}/Zeal.app"